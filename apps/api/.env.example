# =============================================================================
# SWEEPBOT API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# JWT Configuration (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-required-here

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Supabase)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Supabase Authentication
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Stripe Payments
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Redis Cache & Job Queue (Upstash)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@sweepbot.app

# -----------------------------------------------------------------------------
# Error Monitoring (Sentry)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://xxxxxxxxxxxx@xxxxxxxxxxxx.ingest.sentry.io/xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Analytics (PostHog)
# -----------------------------------------------------------------------------
POSTHOG_API_KEY=phc_xxxxxxxxxxxx
POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_RATE_LIMITING=true
ENABLE_SWAGGER_UI=false  # Set to true in development to access API docs at /docs

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info  # debug | info | warn | error

# -----------------------------------------------------------------------------
# Internal Cron Secret
# Shared secret required to call internal cron endpoints:
#   POST /streaks/nightly-check
#   POST /subscriptions/expire-trials
# Pass via header: x-cron-secret: <value>  OR  Authorization: Bearer <value>
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
CRON_SECRET=your-cron-secret-here
