# =============================================================================
# SWEEPBOT API – Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the resulting .env to version control!
#
# Key names here MUST match the validated names in src/utils/env.ts.
# Running the API with an incorrect/missing key will cause startup to fail
# with a descriptive validation error.
# =============================================================================

# -----------------------------------------------------------------------------
# App / Server
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=8080
API_HOST=0.0.0.0
LOG_LEVEL=info          # trace | debug | info | warn | error | fatal

# Allowed CORS origins (comma-separated if multiple)
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Supabase)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Supabase Authentication
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# JWT
# Generate with: openssl rand -base64 48
# Must be at least 32 characters.
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# -----------------------------------------------------------------------------
# Stripe Payments
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Optional: map Stripe price IDs to internal subscription tiers
STRIPE_PRICE_STARTER_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_STARTER_ANNUAL=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO_ANNUAL=price_xxxxxxxxxxxx
STRIPE_PRICE_ANALYST_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_ANALYST_ANNUAL=price_xxxxxxxxxxxx
STRIPE_PRICE_ELITE_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_ELITE_ANNUAL=price_xxxxxxxxxxxx
STRIPE_PRICE_LIFETIME=price_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Redis Cache & Job Queue (Upstash)
# Both are optional -- omit to run without Redis.
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# -----------------------------------------------------------------------------
# Email (Resend)
# RESEND_API_KEY is optional -- omit to disable transactional email.
# EMAIL_FROM and EMAIL_FROM_NAME set the sender address shown to recipients.
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@sweepbot.app
EMAIL_FROM_NAME=SweepBot

# -----------------------------------------------------------------------------
# Supabase Webhook Shared Secret
# Used to authenticate POST /webhooks/supabase requests.
# Generate with: openssl rand -hex 32
# Configure the same value in your Supabase Auth webhook settings.
# -----------------------------------------------------------------------------
SUPABASE_WEBHOOK_SECRET=your-supabase-webhook-secret-here

# -----------------------------------------------------------------------------
# Error Monitoring (Sentry) -- optional
# -----------------------------------------------------------------------------
SENTRY_DSN=https://xxxxxxxxxxxx@xxxxxxxxxxxx.ingest.sentry.io/xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_URL=https://app.sweepbot.app

# Optional: restrict certain admin-only endpoints
ADMIN_SECRET=your-admin-secret-here
