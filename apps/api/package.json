{
  "name": "@sweepbot/api",
  "version": "0.1.0",
  "private": true,
  "description": "SweepBot REST + WebSocket API",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",

    "@supabase/supabase-js": "^2.45.0",
    "@sweepbot/types": "workspace:*",
    "@sweepbot/flows": "workspace:*",
    "dotenv": "^16.0.0",
    "@upstash/redis": "^1.34.0",
    "bullmq": "^5.0.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.8.1",
    "pino": "^9.0.0",
    "postgres": "^3.4.0",
    "resend": "^4.0.0",
    "stripe": "^17.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "drizzle-kit": "^0.27.0",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
