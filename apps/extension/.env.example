# =============================================================================
# SWEEPBOT BROWSER EXTENSION - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
VITE_API_URL=https://api.sweepbot.app/v1

# -----------------------------------------------------------------------------
# Extension Configuration
# -----------------------------------------------------------------------------
VITE_EXTENSION_ID=your-extension-id-here
VITE_VERSION=0.1.0

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
VITE_ENABLE_VOICE_RECORDER=true
VITE_ENABLE_AFFILIATE_LINKS=true
VITE_ENABLE_AUTO_BONUS_DETECTION=true

# -----------------------------------------------------------------------------
# Analytics (PostHog)
# -----------------------------------------------------------------------------
VITE_POSTHOG_API_KEY=phc_xxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
VITE_LOG_LEVEL=info  # debug | info | warn | error
VITE_ENABLE_CONSOLE_LOGS=false
