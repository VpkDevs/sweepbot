# SweepBot Web App Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# API Configuration
# =============================================================================

# API base URL (defaults to /api/v1 if not set)
VITE_API_URL=/api/v1

# =============================================================================
# Supabase Configuration (REQUIRED)
# =============================================================================

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous key (public, safe for client-side)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable analytics (default: true)
VITE_ENABLE_ANALYTICS=true

# Enable/disable debug mode (default: false)
VITE_ENABLE_DEBUG=false

# Enable experimental features (default: false)
VITE_ENABLE_EXPERIMENTAL_FEATURES=false

# =============================================================================
# Third-party Services (Optional)
# =============================================================================

# Sentry DSN for error tracking
# Format: https://abc123@o123456.ingest.sentry.io/1234567
VITE_SENTRY_DSN=

# PostHog API key for analytics
VITE_POSTHOG_KEY=

# =============================================================================
# App Configuration
# =============================================================================

# App name (default: SweepBot)
VITE_APP_NAME=SweepBot

# App URL for OAuth redirects (default: https://app.sweepbot.app)
VITE_APP_URL=https://app.sweepbot.app

