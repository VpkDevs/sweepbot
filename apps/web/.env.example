# =============================================================================
# SWEEPBOT WEB APP - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3000/api/v1

# -----------------------------------------------------------------------------
# Supabase Authentication
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# Stripe Payments (Public Keys Only)
# -----------------------------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Error Monitoring (Sentry)
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=https://xxxxxxxxxxxx@xxxxxxxxxxxx.ingest.sentry.io/xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Analytics (PostHog)
# -----------------------------------------------------------------------------
VITE_POSTHOG_API_KEY=phc_xxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
VITE_LOG_LEVEL=info  # debug | info | warn | error
VITE_ENABLE_CONSOLE_LOGS=false  # Set to true in development for console output
VITE_ENABLE_REMOTE_LOGS=false
VITE_LOG_ENDPOINT=  # Optional endpoint for remote logging in production
