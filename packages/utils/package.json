{
  "name": "@sweepbot/utils",
  "version": "0.1.0",
  "private": true,
  "description": "Shared utility functions for API, web, and extension",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./math": {
      "types": "./src/math.ts",
      "import": "./src/math.ts",
      "default": "./src/math.ts"
    },
    "./string": {
      "types": "./src/string.ts",
      "import": "./src/string.ts",
      "default": "./src/string.ts"
    },
    "./date": {
      "types": "./src/date.ts",
      "import": "./src/date.ts",
      "default": "./src/date.ts"
    },
    "./currency": {
      "types": "./src/currency.ts",
      "import": "./src/currency.ts",
      "default": "./src/currency.ts"
    },
    "./crypto": {
      "types": "./src/crypto.ts",
      "import": "./src/crypto.ts",
      "default": "./src/crypto.ts"
    },
    "./validation": {
      "types": "./src/validation.ts",
      "import": "./src/validation.ts",
      "default": "./src/validation.ts"
    },
    "./logger": {
      "types": "./src/logger.ts",
      "import": "./src/logger.ts",
      "default": "./src/logger.ts"
    }
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2"
  }
}
