{
  "name": "@sweepbot/flows",
  "version": "0.1.0",
  "private": true,
  "description": "SweepBot Flows - Natural language automation engine",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
