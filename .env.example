# =============================================================================
# SWEEPBOT — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (https://supabase.com)
# Create a project, then find these values in Settings > API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key  # Keep secret — server only!
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# REDIS (https://upstash.com)
# Create a Redis database, then copy the connection string
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# -----------------------------------------------------------------------------
# STRIPE (https://stripe.com)
# Dashboard > Developers > API Keys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Stripe Price IDs (create in Stripe Dashboard > Products)
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual
STRIPE_PRICE_ANALYST_MONTHLY=price_analyst_monthly
STRIPE_PRICE_ANALYST_ANNUAL=price_analyst_annual
STRIPE_PRICE_ELITE_MONTHLY=price_elite_monthly
STRIPE_PRICE_ELITE_ANNUAL=price_elite_annual
STRIPE_PRICE_LIFETIME=price_lifetime_one_time

# -----------------------------------------------------------------------------
# RESEND (https://resend.com)
# Dashboard > API Keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@sweepbot.app
EMAIL_FROM_NAME=SweepBot

# -----------------------------------------------------------------------------
# API SERVER
# -----------------------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# JWT secret — generate a random 64-char string
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API URL (used by frontend to know where API is)
NEXT_PUBLIC_API_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
VITE_APP_URL=http://localhost:5173
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# SENTRY (https://sentry.io) — Error monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=appyness
SENTRY_PROJECT=sweepbot-api

# -----------------------------------------------------------------------------
# POSTHOG (https://posthog.com) — Product analytics
# -----------------------------------------------------------------------------
VITE_POSTHOG_KEY=phc_your-posthog-key
VITE_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# PRODUCTION ONLY
# -----------------------------------------------------------------------------
# RAILWAY_STATIC_URL=
# VERCEL_URL=
